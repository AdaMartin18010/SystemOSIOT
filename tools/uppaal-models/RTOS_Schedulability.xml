<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE nta PUBLIC '-//Uppaal Team//DTD Flat System 1.1//EN' 'http://www.it.uu.se/research/group/darts/uppaal/flat-1_1.dtd'>
<nta>
  <declaration>
    // RTOS Schedulability Model: Two periodic tasks under Fixed Priority Scheduling
    // Task 1: period = 10, deadline = 10, wcet = 3, priority = 2 (higher)
    // Task 2: period = 15, deadline = 15, wcet = 4, priority = 1 (lower)
    
    clock t1_period, t1_exec;
    clock t2_period, t2_exec;
    clock cpu; // global time
    
    const int T1_PERIOD = 10;
    const int T1_WCET = 3;
    const int T2_PERIOD = 15;
    const int T2_WCET = 4;
  </declaration>
  <template>
    <name>Task1</name>
    <parameter></parameter>
    <declaration>
      // Task 1 local declarations
    </declaration>
    <location id="id0" x="0" y="0">
      <name>Ready</name>
      <label kind="invariant">t1_period &lt;= T1_PERIOD</label>
    </location>
    <location id="id1" x="100" y="0">
      <name>Running</name>
      <label kind="invariant">t1_exec &lt;= T1_WCET</label>
    </location>
    <location id="id2" x="0" y="100">
      <name>DeadlineMiss</name>
    </location>
    <init ref="id0"/>
    <transition>
      <source ref="id0"/>
      <target ref="id1"/>
      <label kind="guard">t1_period == T1_PERIOD &amp;&amp; t2_exec == 0</label>
      <label kind="assignment">t1_period = 0, t1_exec = 0</label>
    </transition>
    <transition>
      <source ref="id1"/>
      <target ref="id0"/>
      <label kind="guard">t1_exec == T1_WCET</label>
      <label kind="assignment">t1_exec = 0</label>
    </transition>
    <transition>
      <source ref="id0"/>
      <target ref="id2"/>
      <label kind="guard">t1_period &gt; T1_PERIOD</label>
    </transition>
  </template>
  <template>
    <name>Task2</name>
    <parameter></parameter>
    <declaration>
      // Task 2 local declarations
    </declaration>
    <location id="id3" x="0" y="0">
      <name>Ready</name>
      <label kind="invariant">t2_period &lt;= T2_PERIOD</label>
    </location>
    <location id="id4" x="100" y="0">
      <name>Running</name>
      <label kind="invariant">t2_exec &lt;= T2_WCET</label>
    </location>
    <location id="id5" x="0" y="100">
      <name>DeadlineMiss</name>
    </location>
    <init ref="id3"/>
    <transition>
      <source ref="id3"/>
      <target ref="id4"/>
      <label kind="guard">t2_period == T2_PERIOD &amp;&amp; t1_exec == 0</label>
      <label kind="assignment">t2_period = 0, t2_exec = 0</label>
    </transition>
    <transition>
      <source ref="id4"/>
      <target ref="id3"/>
      <label kind="guard">t2_exec == T2_WCET</label>
      <label kind="assignment">t2_exec = 0</label>
    </transition>
    <transition>
      <source ref="id3"/>
      <target ref="id5"/>
      <label kind="guard">t2_period &gt; T2_PERIOD</label>
    </transition>
  </template>
  <system>
    // System composition
    task1 = Task1();
    task2 = Task2();
    system task1, task2;
  </system>
</nta>
