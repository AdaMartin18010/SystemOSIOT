# ============================================================
# SystemOSIOT - GitHub-friendly ignore rules
# 目标：只保留源码、模型与文档；过滤所有工具二进制与编译产物。
# ============================================================

# ------------------------------------------------------------------
# 1. 通用编译产物与依赖目录
# ------------------------------------------------------------------

# Rust / Cargo
debug/
target/
**/*.rs.bk
*.pdb
**/mutants.out*/

# Node / Python 虚拟环境（如后续引入）
node_modules/
venv/
.venv/
__pycache__/
*.pyc

# IDE
.idea/
.vscode/settings.json.local
*.swp
*.swo
*~

# 操作系统文件
.DS_Store
Thumbs.db

# ------------------------------------------------------------------
# 2. 形式化验证工具链二进制与压缩包
# ------------------------------------------------------------------

# 下载的引擎包（大文件，不应提交；README 与脚本除外）
tools/engines/*/
!tools/engines/README.md
tools/engines/*.zip
tools/engines/*.tar.gz
tools/engines/*.tar.bz2
tools/engines/*.tgz
tools/engines/*.exe
tools/engines/*.jar

# 例外：保留源码归档的记录文件（如果将来加入下载脚本）
!tools/engines/.gitkeep

# ------------------------------------------------------------------
# 3. Coq 编译产物
# ------------------------------------------------------------------

*.vo
*.vos
*.vok
*.glob
*.aux
*.cache
.lia.cache

# ------------------------------------------------------------------
# 4. SPIN / Promela 验证产物
# ------------------------------------------------------------------

tools/spin-models/pan
tools/spin-models/pan.c
tools/spin-models/pan.h
tools/spin-models/pan.t
tools/spin-models/pan.b
tools/spin-models/pan.m
tools/spin-models/pan.trail
tools/spin-models/_spin_nvr.tmp

# ------------------------------------------------------------------
# 5. TLA+ 状态转储
# ------------------------------------------------------------------

tools/tla-specifications/states/
tools/tla-specifications/*.dump

# ------------------------------------------------------------------
# 6. PRISM / NuSMV / Alloy 临时产物
# ------------------------------------------------------------------

*.class
*.out.log
*.prism.log
